<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="local" value="../nugets" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- Pin MapBundle.* to the locally-built feed. Without this, NuGet sees the same versions in BOTH
       feeds (the local nupkgs AND anything published on nuget.org) and can pick nondeterministically,
       missing the in-progress build-task / targets changes under test. PackageSourceMapping forces
       MapBundle and every MapBundle.<Region> package to come from `local`; everything else (GeoConvert,
       TUnit, the test SDK …) resolves from nuget.org. -->
  <packageSourceMapping>
    <packageSource key="local">
      <package pattern="MapBundle" />
      <package pattern="MapBundle.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
