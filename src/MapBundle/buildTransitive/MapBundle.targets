<Project>

  <!--
    Shipped in the MapBundle core package and auto-imported (transitively) into any project that
    references a MapBundle.<Region> data package. Each data package's own targets registers its layer
    files as @(MapBundleData) items (with Region metadata); this file decides what happens to them.

    By default the FlatGeobuf layers are copied straight into maps/<Region> next to the app (the
    historical behaviour). Set the properties below to opt out of that, convert to another format, or
    render a preview image instead — all driven by GeoConvert at build time via the ConvertMapData task.

    NOTE: the task is a net10.0 assembly, so the conversion/render path requires building with a
    .NET 10+ SDK's MSBuild ("dotnet build" / "dotnet publish", or VS using a .NET 10 SDK). The default
    raw-copy path needs no task and works under any host.

      MapBundleFormat       any GeoFormat name: GeoJson, TopoJson, Kml, Kmz, Gpx, Wkt, Wkb, Csv,
                            GeoParquet, Shapefile, or FlatGeobuf (the default; copies verbatim).
      MapBundleRenderImages "true" also renders maps/<Region>/<Region>.png.
      MapBundleCopyData     "false" emits no vector data at all (images only).
      MapBundleLayers       semicolon- or comma-separated whitelist of layer names to keep (the rest
                            are dropped before either path runs). Accepts both the MapLayer enum names
                            (Borders, StatesProvinces, Cities, Rivers, Lakes, Coastline, Land, Ocean)
                            and the on-disk filenames (borders, states, cities, …). Case-insensitive.
                            Unset = all layers. Non-layer files (meta.json) are always kept.
      MapBundleExcludeLayers  semicolon- or comma-separated blacklist, applied after MapBundleLayers.
                            Same name accepted as MapBundleLayers.
      MapBundleSimplifyTolerance  a positive number turns on GeoConvert vertex reduction (degrees for
                            DouglasPeucker, degrees² for Visvalingam) before the data/image is written;
                            unset or 0 leaves geometry untouched (and keeps the verbatim .fgb copy).
      MapBundleSimplifyMethod  DouglasPeucker (default) or Visvalingam; only used when a tolerance is set.

    Image toggles (only used when MapBundleRenderImages is true; unset means GeoConvert's own default):
      MapBundleImageWidth, MapBundleImageHeight, MapBundleImagePadding, MapBundleImageProjection,
      MapBundleImageBackground, MapBundleImageOcean, MapBundleImageStroke, MapBundleImageFill,
      MapBundleImageStrokeWidth, MapBundleImagePointRadius, MapBundleImageStrokeAutoScale,
      MapBundleImageLabels, MapBundleImageLabelSize, MapBundleImageLabelColor, MapBundleImageCompression.
  -->

  <PropertyGroup>
    <MapBundleFormat Condition="'$(MapBundleFormat)' == ''">FlatGeobuf</MapBundleFormat>
    <MapBundleRenderImages Condition="'$(MapBundleRenderImages)' == ''">false</MapBundleRenderImages>
    <MapBundleCopyData Condition="'$(MapBundleCopyData)' == ''">true</MapBundleCopyData>
    <MapBundleIntermediateDir Condition="'$(MapBundleIntermediateDir)' == ''">$(IntermediateOutputPath)mapbundle\</MapBundleIntermediateDir>

    <_MapBundleTasksAssembly>$(MSBuildThisFileDirectory)..\tasks\MapBundle.Build.dll</_MapBundleTasksAssembly>
    <!-- The task is only needed when converting away from FlatGeobuf, simplifying, or rendering images. -->
    <_MapBundleNeedsTask Condition="'$(MapBundleFormat)' != 'FlatGeobuf' or '$(MapBundleRenderImages)' == 'true' or ('$(MapBundleSimplifyTolerance)' != '' and '$(MapBundleSimplifyTolerance)' != '0')">true</_MapBundleNeedsTask>
  </PropertyGroup>

  <UsingTask
    TaskName="MapBundle.Build.ConvertMapData"
    AssemblyFile="$(_MapBundleTasksAssembly)"
    Condition="'$(_MapBundleNeedsTask)' == 'true'" />

  <!-- Layer subset filter: when the consumer set MapBundleLayers / MapBundleExcludeLayers, drop the
       MapBundleData items that don't survive the filter BEFORE either downstream path consumes them
       (so the convert path doesn't waste work on layers the consumer is about to throw away, and the
       raw-copy path doesn't stage them into maps/<Region>). Non-layer files (meta.json) are always
       kept — both properties act only on the eight known layer filenames. -->
  <Target Name="_MapBundleFilterLayers"
          BeforeTargets="_MapBundleConvert;_MapBundleCopyRaw"
          Condition="('$(MapBundleLayers)' != '' or '$(MapBundleExcludeLayers)' != '') and '@(MapBundleData)' != ''">
    <PropertyGroup>
      <!-- Normalise each list to a ;-padded, lowercase token string. Padding makes Contains() an exact-
           token match (so 'land' doesn't match 'lakes'). Accept either ; or , as separator and strip
           spaces, so 'Borders, Cities' and 'borders;cities' both work. Translate the one enum-name →
           on-disk-filename mismatch (StatesProvinces → states) so the consumer can use the enum names
           they already know from C# / meta.json without having to translate to the storage convention. -->
      <_MapBundleLayersNorm Condition="'$(MapBundleLayers)' != ''">;$([System.String]::Copy('$(MapBundleLayers)').ToLowerInvariant().Replace(',', ';').Replace(' ', '').Replace('statesprovinces', 'states'));</_MapBundleLayersNorm>
      <_MapBundleExcludeLayersNorm Condition="'$(MapBundleExcludeLayers)' != ''">;$([System.String]::Copy('$(MapBundleExcludeLayers)').ToLowerInvariant().Replace(',', ';').Replace(' ', '').Replace('statesprovinces', 'states'));</_MapBundleExcludeLayersNorm>
      <!-- The eight on-disk layer filenames, ;-padded. The whitelist only ever removes items whose
           filename is in this set; everything else (meta.json, future sidecars) is preserved. -->
      <_MapBundleKnownLayerFiles>;borders;cities;rivers;lakes;states;coastline;land;ocean;</_MapBundleKnownLayerFiles>
    </PropertyGroup>
    <!-- Validate: every token in either list must be a known layer (after normalisation). Without this
         a typo like 'Boders' silently removes every real layer (it's not in the include list, and the
         include list isn't itself empty so the filter runs), leaving the consumer with an empty maps/
         folder and no signal anything went wrong.

         The two normalised properties are concatenated and fed to Include="…". MSBuild splits Include
         values on ';' to produce one item per token — but a ';' inside a property value returned by a
         property function like .Replace() is auto-escaped (as %3B) so it survives later parsing as a
         literal. That's the opposite of what we want here: we need those embedded ';' to act as token
         separators. [MSBuild]::Unescape converts the %3B back to a real ';' so Include sees them and
         splits the value into one item per token. -->
    <ItemGroup>
      <_MapBundleRequestedLayerTokens Include="$([MSBuild]::Unescape('$(_MapBundleLayersNorm)$(_MapBundleExcludeLayersNorm)'))" />
      <_MapBundleUnknownLayerTokens Include="@(_MapBundleRequestedLayerTokens)"
                                    Condition="'%(Identity)' != '' and !$(_MapBundleKnownLayerFiles.Contains(';%(Identity);'))" />
    </ItemGroup>
    <Error Condition="'@(_MapBundleUnknownLayerTokens)' != ''"
           Text="MapBundleLayers / MapBundleExcludeLayers contains unknown layer name(s): @(_MapBundleUnknownLayerTokens, ', '). Known layers: Borders, StatesProvinces, Cities, Rivers, Lakes, Coastline, Land, Ocean (the on-disk filenames borders/states/cities/rivers/lakes/coastline/land/ocean are also accepted)." />

    <ItemGroup>
      <!-- Whitelist: drop layer files NOT named in MapBundleLayers. -->
      <MapBundleData Remove="@(MapBundleData)"
                     Condition="'$(_MapBundleLayersNorm)' != '' and $(_MapBundleKnownLayerFiles.Contains(';%(Filename);')) and !$(_MapBundleLayersNorm.Contains(';%(Filename);'))" />
      <!-- Blacklist: drop layer files named in MapBundleExcludeLayers. Non-layer files survive because
           their filename isn't in the user's exclude list. -->
      <MapBundleData Remove="@(MapBundleData)"
                     Condition="'$(_MapBundleExcludeLayersNorm)' != '' and $(_MapBundleExcludeLayersNorm.Contains(';%(Filename);'))" />
    </ItemGroup>
  </Target>

  <!-- Default, task-free path: copy the raw FlatGeobuf data straight into maps/<Region>. -->
  <Target Name="_MapBundleCopyRaw"
          BeforeTargets="AssignTargetPaths"
          Condition="'$(MapBundleCopyData)' == 'true' and '$(_MapBundleNeedsTask)' != 'true' and '@(MapBundleData)' != ''">
    <ItemGroup>
      <None Include="@(MapBundleData)">
        <!-- Qualify every metadata reference to MapBundleData so the batch is over MapBundleData, not
             the consumer's global None list (an unqualified %(Region) batches over None and fails for
             any None item lacking Region metadata, e.g. Verify *.verified.* snapshots — MSB4096). -->
        <Link>maps\%(MapBundleData.Region)\%(MapBundleData.Filename)%(MapBundleData.Extension)</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <Visible>false</Visible>
      </None>
    </ItemGroup>
  </Target>

  <!-- Conversion / render path: run GeoConvert and stage whatever it produces into maps/<Region>. -->
  <Target Name="_MapBundleConvert"
          BeforeTargets="AssignTargetPaths"
          Condition="'$(_MapBundleNeedsTask)' == 'true' and '@(MapBundleData)' != ''">
    <MapBundle.Build.ConvertMapData
        SourceFiles="@(MapBundleData)"
        OutputDirectory="$(MapBundleIntermediateDir)"
        Format="$(MapBundleFormat)"
        CopyData="$(MapBundleCopyData)"
        SimplifyTolerance="$(MapBundleSimplifyTolerance)"
        SimplifyMethod="$(MapBundleSimplifyMethod)"
        RenderImages="$(MapBundleRenderImages)"
        ImageWidth="$(MapBundleImageWidth)"
        ImageHeight="$(MapBundleImageHeight)"
        ImagePadding="$(MapBundleImagePadding)"
        ImageProjection="$(MapBundleImageProjection)"
        ImageBackground="$(MapBundleImageBackground)"
        ImageOcean="$(MapBundleImageOcean)"
        ImageStroke="$(MapBundleImageStroke)"
        ImageFill="$(MapBundleImageFill)"
        ImageStrokeWidth="$(MapBundleImageStrokeWidth)"
        ImagePointRadius="$(MapBundleImagePointRadius)"
        ImageStrokeAutoScale="$(MapBundleImageStrokeAutoScale)"
        ImageLabels="$(MapBundleImageLabels)"
        ImageLabelSize="$(MapBundleImageLabelSize)"
        ImageLabelColor="$(MapBundleImageLabelColor)"
        ImageCompression="$(MapBundleImageCompression)">
      <Output ItemName="_MapBundleConverted" TaskParameter="ConvertedFiles" />
    </MapBundle.Build.ConvertMapData>

    <ItemGroup>
      <None Include="@(_MapBundleConverted)">
        <!-- Qualify to _MapBundleConverted for the same reason as _MapBundleCopyRaw above: keep the
             batch over the converted files, not the consumer's global None list. -->
        <Link>maps\%(_MapBundleConverted.Region)\%(_MapBundleConverted.Filename)%(_MapBundleConverted.Extension)</Link>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <Visible>false</Visible>
      </None>
    </ItemGroup>
  </Target>

</Project>
